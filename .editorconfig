root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.lua]
indent_size = 4

[*.cs]
indent_size = 4

[*.csproj]
indent_size = 2

[*.slnx]
indent_size = 2

[*.json]
indent_size = 2

[*.xml]
indent_size = 2

[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2

[*.sh]
end_of_line = lf

[*.cmd]
end_of_line = crlf

[*.bat]
end_of_line = crlf
